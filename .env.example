# Runtime environment. Gunakan "production" untuk deployment agar validasi konfigurasi aman aktif.
IPB_ENVIRONMENT=development

# SQLAlchemy database URL.
# Development default aplikasi: sqlite+pysqlite:///./ipb_smart_reserve_hub.db
# Production contoh: postgresql+psycopg://user:password@host:5432/dbname
IPB_DATABASE_URL=sqlite+pysqlite:///./ipb_smart_reserve_hub.db

# Secret untuk token autentikasi. Ganti di production dengan nilai acak yang kuat.
IPB_SECRET_KEY=dev-secret-change-me

# Domain email mahasiswa yang boleh registrasi mandiri, pisahkan dengan koma jika lebih dari satu.
IPB_ALLOWED_STUDENT_EMAIL_DOMAINS=apps.ipb.ac.id
